# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder here holds only machine-specific local settings (absolute
# paths), so it is ignored. Re-add task/launch configs intentionally if needed.
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
/build/
/coverage/

# Generated code (freezed + Isar + json_serializable). These are regenerated by
# `dart run build_runner build --delete-conflicting-outputs` and are NOT committed
# — the canonical source is the generator, not hand-edited copies. See CLAUDE.md.
**/*.g.dart
**/*.freezed.dart
**/*.config.dart

# Firebase (secrets / generated platform config — see docs/SETUP.md)
google-services.json
GoogleService-Info.plist
.firebase/

# Claude Code local/personal settings (machine-specific permission allowlist)
.claude/settings.local.json

# Local backups / exported user data
*.habitview

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
